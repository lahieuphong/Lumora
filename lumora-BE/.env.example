# ===== Django =====
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# ===== PostgreSQL =====
POSTGRES_DB=lumora
POSTGRES_USER=lumora
POSTGRES_PASSWORD=lumora
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===== CORS (frontend dev server) =====
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== OTP / email =====
# Console backend prints OTP codes to the backend logs (great for development).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@lumora.app
OTP_TTL_MINUTES=5
RESET_TOKEN_TTL_MINUTES=10

# ===== Demo seed account (created on startup) =====
DEMO_EMAIL=demo@lumora.app
DEMO_PASSWORD=lumora123
